#!/bin/bash

set -euo pipefail

PATH="$PATH:node_modules/.bin"

main () {
  if [[ $# -lt 1 ]]; then
    cmd_help
  fi

  local command="cmd_$1"
  shift

  "$command" "$@"
}

cmd_help () {
  local available_commands=$(set | perl -nle'print $& while m{^cmd_\K\w+}g')
  echo -e "Available commands:\n$available_commands"
  exit 1
}

cmd_dev () {
  yarn dev:init
  concurrently --names "SDK,PLAYGROUND" -c "blue,magenta" "yarn build:watch" "cd playground && yarn dev"
}

cmd_test_playground () {
  # Strategy: Validate playground installation, build, and runtime in CI
  # This ensures the developer experience doesn't break

  echo "Building SDK..."
  yarn build

  echo "Installing playground dependencies..."
  yarn dev:init

  echo "Building playground..."
  cd playground
  yarn build

  # Validate build outputs exist
  test -f dist/main.js || { echo "Error: main.js not found"; exit 1; }
  test -f dist/preload.js || { echo "Error: preload.js not found"; exit 1; }
  test -f dist/renderer.js || { echo "Error: renderer.js not found"; exit 1; }
  test -f dist/index.html || { echo "Error: index.html not found"; exit 1; }

  echo "Testing playground runtime..."
  # Launch Electron in background with 10s timeout, capture output
  # Use xvfb-run in CI (with --no-sandbox for root user), run directly for local development
  if [ "${CI:-false}" = "true" ]; then
    echo "CI environment detected, using xvfb for headless execution"
    timeout 10 xvfb-run -a electron . --no-sandbox > ../playground.log 2>&1 &
  else
    echo "Local environment detected, running without xvfb"
    timeout 10 yarn start > ../playground.log 2>&1 &
  fi
  APP_PID=$!

  # Wait for initialization
  sleep 5

  # Verify still running (not crashed)
  if ps -p $APP_PID > /dev/null; then
    echo "Playground launched successfully"
    kill $APP_PID || true
    wait $APP_PID || true
  else
    echo "Error: Playground crashed during startup"
    cat ../playground.log
    exit 1
  fi
}

cmd_init_submodule () {
  if [ ! -d "rum-events-format/.git" ]; then
    echo "Initializing rum-events-format submodule..."
    git submodule update --init --recursive rum-events-format
  else
    echo "rum-events-format submodule already initialized"
  fi
}

cmd_update_submodule () {
  echo "Updating rum-events-format submodule..."
  git submodule update --remote rum-events-format
  echo "✓ Submodule updated to latest master"
}

cmd_sync_schemas () {
  cmd_update_submodule
  cmd_generate_schemas
  echo ""
  echo "✓ Schema sync complete"
}

cmd_generate_schemas () {
  cmd_build_fork
  node scripts/generate-schema-types.ts
}

cmd_build_fork () {
  echo "Building json-schema-to-typescript fork..."

  if [ ! -d "node_modules/json-schema-to-typescript" ]; then
    echo "Error: json-schema-to-typescript not found in node_modules"
    exit 1
  fi

  cd node_modules/json-schema-to-typescript

  # Remove any existing dist
  rm -rf dist

  # Build with TypeScript, ignoring type errors
  # The fork (v11.0.1) builds successfully despite type errors
  # This is expected and documented in rum-events-format
  npx tsc --skipLibCheck -d 2>&1 || true

  # Move files if they're in the wrong place (tsconfig outputs to dist/ not dist/src/)
  if [ -f "dist/cli.js" ] && [ ! -d "dist/src" ]; then
    mkdir -p dist/src
    mv dist/*.js dist/*.d.ts dist/*.map dist/src/ 2>/dev/null || true
    if [ -d "dist/types" ]; then
      mv dist/types dist/src/
    fi
  fi

  cd ../..
  echo "✓ Fork build complete"
}

main "$@"
