{
  "name": "@datadog/electron-sdk",
  "version": "0.1.0",
  "description": "DataDog SDK for Electron applications",
  "packageManager": "yarn@4.12.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "postinstall": "scripts/cli init_submodule",
    "json-schemas:sync": "scripts/cli sync_schemas",
    "json-schemas:generate": "scripts/cli generate_schemas",
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "typecheck": "tsc -b --noEmit",
    "dev:init": "cd playground && yarn install",
    "dev": "scripts/cli dev",
    "test": "vitest",
    "test:unit": "vitest run --coverage",
    "test:e2e:init": "yarn build && cd e2e/app && yarn install && yarn build",
    "test:e2e": "playwright test -c e2e",
    "test:e2e:debug": "playwright test -c e2e --debug",
    "test:e2e:ci": "yarn test:e2e:init && xvfb-run -a yarn test:e2e",
    "lint": "yarn dev:init && yarn test:e2e:init && eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@datadog/browser-core": "6.26.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.0",
    "@playwright/test": "1.58.2",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-typescript": "12.1.2",
    "@types/node": "24.10.11",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "concurrently": "9.2.1",
    "electron": "40.2.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-force-barrel-imports": "1.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "63.0.0",
    "husky": "9.1.7",
    "json-schema-to-typescript": "11.0.5",
    "lint-staged": "16.3.1",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "rollup": "4.59.0",
    "rollup-plugin-dts": "6.3.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "electron": "40.2.1"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:DataDog/electron-sdk.git"
  },
  "volta": {
    "node": "25.3.0",
    "yarn": "4.12.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "*.{js,mjs,cjs,json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}
