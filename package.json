{
  "name": "@datadog/electron-sdk",
  "version": "0.1.0",
  "description": "DataDog SDK for Electron applications",
  "packageManager": "yarn@4.12.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "postinstall": "scripts/cli init_submodule",
    "json-schemas:sync": "scripts/cli sync_schemas",
    "json-schemas:generate": "scripts/cli generate_schemas",
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "typecheck": "tsc -b",
    "dev:init": "cd playground && yarn install",
    "dev": "scripts/cli dev",
    "test": "vitest",
    "test:unit": "vitest run --coverage",
    "test:e2e:init": "yarn build && cd e2e/app && yarn install && yarn build",
    "test:e2e": "playwright test -c e2e",
    "test:e2e:debug": "playwright test -c e2e --debug",
    "test:e2e:ci": "yarn test:e2e:init && xvfb-run -a yarn test:e2e",
    "lint": "yarn dev:init && yarn test:e2e:init && eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@datadog/browser-core": "6.26.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.55.1",
    "@rollup/plugin-commonjs": "28.0.2",
    "@rollup/plugin-node-resolve": "16.0.0",
    "@rollup/plugin-typescript": "12.1.2",
    "@types/node": "25.0.9",
    "@vitest/coverage-v8": "4.0.17",
    "@vitest/ui": "4.0.17",
    "concurrently": "9.1.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "json-schema-to-typescript": "bcaudan/json-schema-to-typescript#bcaudan/add-readonly-support",
    "lint-staged": "16.2.7",
    "playwright": "1.55.1",
    "prettier": "3.8.0",
    "rollup": "4.30.1",
    "rollup-plugin-dts": "6.1.1",
    "tslib": "2.8.1",
    "typescript": "5.7.3",
    "typescript-eslint": "8.53.0",
    "vitest": "4.0.17"
  },
  "peerDependencies": {
    "electron": ">=30.0.0 <41"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:DataDog/electron-sdk.git"
  },
  "volta": {
    "node": "25.3.0",
    "yarn": "4.12.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "*.{js,mjs,cjs,json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}
