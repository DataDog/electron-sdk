{
  "name": "electron-sdk-playground",
  "version": "0.1.0",
  "private": true,
  "description": "Playground for testing @datadog/electron-sdk",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.renderer.json && cp src/index.html dist/index.html",
    "build:watch": "concurrently \"tsc --watch\" \"tsc -p tsconfig.renderer.json --watch\"",
    "start": "yarn build && electron .",
    "dev": "yarn build && concurrently \"yarn build:watch\" \"electron .\""
  },
  "dependencies": {
    "@datadog/electron-sdk": "portal:.."
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "chokidar": "5.0.0",
    "concurrently": "9.2.1",
    "electron": "39.1.1",
    "electron-reloader": "1.2.3",
    "typescript": "5.9.3"
  }
}
