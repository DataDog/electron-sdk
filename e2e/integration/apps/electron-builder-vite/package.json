{
  "name": "electron-builder-vite",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.17.1",
  "main": "dist/main.js",
  "integration": {
    "devMain": "dist/main.js",
    "packagedBinary": {
      "darwin-arm64": "out/mac-arm64/electron-builder-vite.app/Contents/MacOS/electron-builder-vite",
      "darwin-x64": "out/mac/electron-builder-vite.app/Contents/MacOS/electron-builder-vite",
      "linux": "out/linux-unpacked/electron-builder-vite",
      "win32": "out/win-unpacked/electron-builder-vite.exe"
    }
  },
  "scripts": {
    "build": "vite build -c vite.main.config.ts && vite build -c vite.preload.config.ts && vite build -c vite.renderer.config.ts",
    "package": "yarn build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "@datadog/browser-rum": "7.5.0",
    "@datadog/electron-sdk": "file:../../integration-sdk.tgz"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "electron": "41.1.0",
    "electron-builder": "26.15.3",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  }
}
