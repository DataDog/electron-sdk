{
  "name": "forge-esbuild-esm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.17.0",
  "main": "dist/main.mjs",
  "integration": {
    "devMain": "dist/main.mjs",
    "packagedBinary": {
      "darwin": "out/forge-esbuild-esm-darwin-{arch}/forge-esbuild-esm.app/Contents/MacOS/forge-esbuild-esm",
      "linux": "out/forge-esbuild-esm-linux-{arch}/forge-esbuild-esm",
      "win32": "out/forge-esbuild-esm-win32-{arch}/forge-esbuild-esm.exe"
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "start": "yarn build && electron .",
    "package": "yarn build && electron-forge package"
  },
  "dependencies": {
    "@datadog/browser-rum": "7.4.0",
    "@datadog/electron-sdk": "file:../../integration-sdk.tgz"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@types/node": "24.13.2",
    "electron": "41.8.0",
    "esbuild": "0.28.1",
    "typescript": "5.9.3"
  }
}
