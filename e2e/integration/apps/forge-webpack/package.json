{
  "name": "forge-webpack",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "main": ".webpack/main",
  "integration": {
    "devMain": ".webpack/{arch}/main/index.js",
    "packagedBinary": {
      "darwin": "out/forge-webpack-darwin-{arch}/forge-webpack.app/Contents/MacOS/forge-webpack",
      "linux": "out/forge-webpack-linux-{arch}/forge-webpack",
      "win32": "out/forge-webpack-win32-{arch}/forge-webpack.exe"
    }
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package"
  },
  "dependencies": {
    "@datadog/browser-rum": "7.4.0",
    "@datadog/electron-sdk": "file:../../integration-sdk.tgz"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/plugin-webpack": "7.11.2",
    "@types/node": "24.13.2",
    "@vercel/webpack-asset-relocator-loader": "1.10.0",
    "css-loader": "7.1.4",
    "electron": "41.1.0",
    "node-loader": "2.1.0",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.1",
    "typescript": "6.0.3",
    "webpack": "5.107.2"
  }
}
